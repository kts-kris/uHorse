# OpenClaw 环境变量配置示例
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ================================
# 服务器配置
# ================================
OPENCLAW_SERVER_HOST=127.0.0.1
OPENCLAW_SERVER_PORT=8080

# ================================
# 数据库配置
# ================================
# Docker 环境
OPENCLAW_DATABASE_URL=postgresql://openclaw:password@localhost:5432/openclaw

# 本地 PostgreSQL
# OPENCLAW_DATABASE_URL=postgresql://openclaw:password@127.0.0.1:5432/openclaw

# ================================
# Redis 配置
# ================================
# Docker 环境
OPENCLAW_REDIS_URL=redis://localhost:6379

# 本地 Redis
# OPENCLAW_REDIS_URL=redis://127.0.0.1:6379

# ================================
# 日志配置
# ================================
# 日志级别: error, warn, info, debug, trace
RUST_LOG=info

# ================================
# 安全配置
# ================================
# JWT 密钥 (生产环境必须更改！)
OPENCLAW_JWT_SECRET=test-secret-for-development-only-do-not-use-in-production

# ================================
# 通道配置 (可选)
# ================================
# Telegram Bot Token (可选)
# OPENCLAW_TELEGRAM_BOT_TOKEN=your_bot_token_here

# Slack Bot Token (可选)
# OPENCLAW_SLACK_BOT_TOKEN=your_slack_token_here
# OPENCLAW_SLACK_SIGNING_SECRET=your_signing_secret_here

# Discord Bot Token (可选)
# OPENCLAW_DISCORD_BOT_TOKEN=your_discord_token_here

# WhatsApp Access Token (可选)
# OPENCLAW_WHATSAPP_ACCESS_TOKEN=your_whatsapp_token_here

# ================================
# 数据目录
# ================================
OPENCLAW_DATA_DIR=./data
OPENCLAW_LOG_DIR=./logs
